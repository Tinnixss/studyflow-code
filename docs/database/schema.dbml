// docs/database/schema.dbml

Table estudantes {
  id integer [primary key, increment] // INT eficiente para chave primária
  nome varchar [not null]
  idade integer [not null]
  foco varchar [not null]
  criado_em timestamp [default: `now()`]
}

Table cronogramas {
  id integer [primary key, increment]
  estudante_id integer [not null]
  materia varchar [not null]
  horas_semanais integer [not null]
  prioridade varchar // Calculada pelo algoritmo P = U x C
  prazo date
  status varchar [default: 'pendente']
}

Table sessoes_foco {
  id integer [primary key, increment]
  estudante_id integer [not null]
  duracao_minutos integer [default: 25] // Padrão Pomodoro
  rendimento_nota integer // Nota de 1 a 5 para o rendimento
  concluida_em timestamp [default: `now()`]
}

// Relacionamentos e Cardinalidades (Chaves Estrangeiras)
// Um estudante pode ter muitos cronogramas (1:N)
Ref: cronogramas.estudante_id > estudantes.id

// Um estudante pode realizar várias sessões de foco/Pomodoro (1:N)
Ref: sessoes_foco.estudante_id > estudantes.id